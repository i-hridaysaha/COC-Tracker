# Copy this file to .env for local runs. .env is gitignored.
# On GitHub, set these as repository secrets instead
# (Settings > Secrets and variables > Actions).

COC_EMAIL=you@example.com
COC_PASSWORD=your-developer-portal-password

# One or more in-game tags, comma-separated. Main first, then alts.
COC_PLAYER_TAGS=#MAINTAG,#ALTTAG1,#ALTTAG2
